{"screenId":"aa627bee9b9b4b95b6c377c22006fad9","projectId":"1898094979057080829","htmlContent":"<!DOCTYPE html>\n\n<html lang=\"pt-BR\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>Gram├ítica Pro: Classifica├º├úo de Verbos</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n        tailwind.config = {\n          darkMode: \"class\",\n          theme: {\n            extend: {\n              \"colors\": {\n                      \"primary-fixed\": \"#dbe1ff\",\n                      \"inverse-on-surface\": \"#eaf1ff\",\n                      \"primary-container\": \"#1a56db\",\n                      \"on-tertiary-fixed\": \"#410002\",\n                      \"surface-variant\": \"#d9e3f4\",\n                      \"primary-fixed-dim\": \"#b5c4ff\",\n                      \"error\": \"#ba1a1a\",\n                      \"outline-variant\": \"#c3c5d7\",\n                      \"error-container\": \"#ffdad6\",\n                      \"surface-container\": \"#e5eeff\",\n                      \"surface-bright\": \"#f8f9ff\",\n                      \"tertiary-container\": \"#c30d17\",\n                      \"surface-container-lowest\": \"#ffffff\",\n                      \"surface-container-high\": \"#dfe9fa\",\n                      \"surface-container-highest\": \"#d9e3f4\",\n                      \"on-primary\": \"#ffffff\",\n                      \"secondary\": \"#006c4a\",\n                      \"tertiary-fixed\": \"#ffdad6\",\n                      \"on-error-container\": \"#93000a\",\n                      \"on-secondary-fixed\": \"#002114\",\n                      \"on-primary-fixed\": \"#00174d\",\n                      \"surface\": \"#f8f9ff\",\n                      \"secondary-fixed-dim\": \"#68dba9\",\n                      \"primary\": \"#003fb1\",\n                      \"outline\": \"#737686\",\n                      \"tertiary-fixed-dim\": \"#ffb4ab\",\n                      \"background\": \"#f8f9ff\",\n                      \"inverse-surface\": \"#27313e\",\n                      \"on-tertiary-fixed-variant\": \"#93000b\",\n                      \"on-primary-fixed-variant\": \"#003dab\",\n                      \"on-secondary\": \"#ffffff\",\n                      \"tertiary\": \"#98000c\",\n                      \"on-secondary-container\": \"#00714e\",\n                      \"on-tertiary\": \"#ffffff\",\n                      \"on-tertiary-container\": \"#ffd3cd\",\n                      \"surface-container-low\": \"#eef4ff\",\n                      \"secondary-fixed\": \"#85f8c4\",\n                      \"on-surface\": \"#121c28\",\n                      \"on-error\": \"#ffffff\",\n                      \"secondary-container\": \"#82f5c1\",\n                      \"surface-dim\": \"#d1dbec\",\n                      \"on-secondary-fixed-variant\": \"#005137\",\n                      \"on-background\": \"#121c28\",\n                      \"surface-tint\": \"#1353d8\",\n                      \"inverse-primary\": \"#b5c4ff\",\n                      \"on-primary-container\": \"#d4dcff\",\n                      \"on-surface-variant\": \"#434654\"\n              },\n              \"borderRadius\": {\n                      \"DEFAULT\": \"0.25rem\",\n                      \"lg\": \"0.5rem\",\n                      \"xl\": \"0.75rem\",\n                      \"full\": \"9999px\"\n              },\n              \"spacing\": {\n                      \"margin-mobile\": \"16px\",\n                      \"gutter\": \"24px\",\n                      \"card-padding\": \"32px\",\n                      \"base\": \"8px\",\n                      \"container-max\": \"800px\"\n              },\n              \"fontFamily\": {\n                      \"headline-lg\": [\"Inter\"],\n                      \"headline-lg-mobile\": [\"Inter\"],\n                      \"label-md\": [\"Inter\"],\n                      \"body-lg\": [\"Inter\"],\n                      \"headline-md\": [\"Inter\"],\n                      \"label-sm\": [\"Inter\"],\n                      \"body-md\": [\"Inter\"]\n              },\n              \"fontSize\": {\n                      \"headline-lg\": [\"32px\", { \"lineHeight\": \"40px\", \"fontWeight\": \"700\" }],\n                      \"headline-lg-mobile\": [\"24px\", { \"lineHeight\": \"32px\", \"fontWeight\": \"700\" }],\n                      \"label-md\": [\"14px\", { \"lineHeight\": \"20px\", \"letterSpacing\": \"0.02em\", \"fontWeight\": \"600\" }],\n                      \"body-lg\": [\"18px\", { \"lineHeight\": \"28px\", \"fontWeight\": \"400\" }],\n                      \"headline-md\": [\"24px\", { \"lineHeight\": \"32px\", \"fontWeight\": \"600\" }],\n                      \"label-sm\": [\"12px\", { \"lineHeight\": \"16px\", \"fontWeight\": \"500\" }],\n                      \"body-md\": [\"16px\", { \"lineHeight\": \"24px\", \"fontWeight\": \"400\" }]\n              }\n            }\n          }\n        }\n    </script>\n<style>\n        .material-symbols-outlined {\n            font-family: 'Material Symbols Outlined';\n            font-weight: normal;\n            font-style: normal;\n            font-size: 24px;\n            line-height: 1;\n            letter-spacing: normal;\n            text-transform: none;\n            display: inline-block;\n            white-space: nowrap;\n            word-wrap: normal;\n            direction: ltr;\n            -webkit-font-feature-settings: 'liga';\n            -webkit-font-smoothing: antialiased;\n        }\n        \n        body { background-color: #F9FAFB; }\n        \n        .quiz-option {\n            transition: all 0.2s ease-in-out;\n            cursor: pointer;\n        }\n        \n        .quiz-option:hover:not(.selected):not(.disabled) {\n            border-color: #003fb1;\n            background-color: #e5eeff;\n            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);\n        }\n        \n        .quiz-option.selected {\n            border-color: #003fb1;\n            background-color: #e5eeff;\n            box-shadow: inset 0 0 0 1px #003fb1;\n        }\n        \n        .quiz-option.disabled {\n            cursor: default;\n            opacity: 0.8;\n        }\n        \n        .quiz-option.correct {\n            border-color: #006c4a;\n            background-color: #e6f6f0;\n            box-shadow: inset 0 0 0 1px #006c4a;\n        }\n        \n        .quiz-option.incorrect {\n            border-color: #ba1a1a;\n            background-color: #ffdad6;\n            box-shadow: inset 0 0 0 1px #ba1a1a;\n        }\n        \n        .toast-enter {\n            animation: toast-in-right 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;\n        }\n        \n        @keyframes toast-in-right {\n            0% { transform: translateX(1000px); opacity: 0; }\n            100% { transform: translateX(0); opacity: 1; }\n        }\n    </style>\n</head>\n<body class=\"bg-background text-on-background pb-32 md:pb-0 pt-16 font-body-md\">\n<!-- TopAppBar -->\n<header class=\"bg-surface dark:bg-inverse-surface border-b border-outline-variant dark:border-outline fixed top-0 w-full z-50 flex justify-between items-center px-gutter h-16 max-w-container-max mx-auto shadow-sm\">\n<div class=\"font-headline-md text-headline-md font-bold text-primary dark:text-inverse-primary\">\n            Gram├ítica Pro\n        </div>\n<!-- Web Nav -->\n<nav class=\"hidden md:flex gap-6 h-full items-end\">\n<a class=\"text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-inverse-primary transition-colors cursor-pointer active:opacity-80 pb-4 font-label-md text-label-md\" href=\"#\">Teoria</a>\n<a class=\"text-primary dark:text-inverse-primary border-b-2 border-primary dark:border-inverse-primary pb-4 font-label-md text-label-md\" href=\"#\">Pr├ítica</a>\n<a class=\"text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-inverse-primary transition-colors cursor-pointer active:opacity-80 pb-4 font-label-md text-label-md\" href=\"#\">Desafios</a>\n<a class=\"text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-inverse-primary transition-colors cursor-pointer active:opacity-80 pb-4 font-label-md text-label-md\" href=\"#\">Progresso</a>\n</nav>\n<div class=\"font-label-md text-label-md text-primary dark:text-inverse-primary cursor-pointer hidden md:block\">\n            Perfil\n        </div>\n</header>\n<main class=\"max-w-container-max mx-auto px-margin-mobile md:px-0 py-8 space-y-12\">\n<header class=\"text-center space-y-4\">\n<h1 class=\"font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface\">Classifica├º├úo de Verbos</h1>\n<p class=\"font-body-lg text-body-lg text-on-surface-variant\">Aprimore seu conhecimento sobre transitividade verbal com teoria aplicada e pr├ítica intensiva.</p>\n</header>\n<!-- Theory Section -->\n<section class=\"space-y-6\">\n<h2 class=\"font-headline-md text-headline-md text-on-surface border-b border-outline-variant pb-2\">Resumo Te├│rico</h2>\n<div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4\">\n<!-- VTD -->\n<div class=\"bg-surface-container-lowest rounded-xl p-6 border border-outline-variant shadow-sm hover:shadow-md transition-shadow\">\n<div class=\"flex items-center gap-2 mb-3 text-primary\">\n<span class=\"material-symbols-outlined\" data-icon=\"description\">description</span>\n<h3 class=\"font-label-md text-label-md uppercase tracking-wider\">Verbo Transitivo Direto (VTD)</h3>\n</div>\n<p class=\"font-body-md text-body-md text-on-surface-variant mb-4\">Exige complemento sem preposi├º├úo obrigat├│ria (Objeto Direto).</p>\n<div class=\"bg-surface-container rounded p-3 font-label-md text-label-md text-on-surface\">\n                        Exemplo: O aluno <span class=\"text-primary underline\">comprou</span> <span class=\"font-bold\">o livro</span>.\n                    </div>\n</div>\n<!-- VTI -->\n<div class=\"bg-surface-container-lowest rounded-xl p-6 border border-outline-variant shadow-sm hover:shadow-md transition-shadow\">\n<div class=\"flex items-center gap-2 mb-3 text-secondary\">\n<span class=\"material-symbols-outlined\" data-icon=\"link\">link</span>\n<h3 class=\"font-label-md text-label-md uppercase tracking-wider\">Verbo Transitivo Indireto (VTI)</h3>\n</div>\n<p class=\"font-body-md text-body-md text-on-surface-variant mb-4\">Exige complemento com preposi├º├úo obrigat├│ria (Objeto Indireto).</p>\n<div class=\"bg-surface-container rounded p-3 font-label-md text-label-md text-on-surface\">\n                        Exemplo: A crian├ºa <span class=\"text-secondary underline\">precisa</span> <span class=\"font-bold\">de afeto</span>.\n                    </div>\n</div>\n<!-- VTDI -->\n<div class=\"bg-surface-container-lowest rounded-xl p-6 border border-outline-variant shadow-sm hover:shadow-md transition-shadow\">\n<div class=\"flex items-center gap-2 mb-3 text-tertiary\">\n<span class=\"material-symbols-outlined\" data-icon=\"account_tree\">account_tree</span>\n<h3 class=\"font-label-md text-label-md uppercase tracking-wider\">Verbo Transitivo Direto e Indireto (VTDI)</h3>\n</div>\n<p class=\"font-body-md text-body-md text-on-surface-variant mb-4\">Exige dois complementos: um sem e outro com preposi├º├úo.</p>\n<div class=\"bg-surface-container rounded p-3 font-label-md text-label-md text-on-surface\">\n                        Exemplo: <span class=\"text-tertiary underline\">Deu</span> <span class=\"font-bold\">a not├¡cia</span> <span class=\"font-bold italic\">aos pais</span>.\n                    </div>\n</div>\n<!-- VI -->\n<div class=\"bg-surface-container-lowest rounded-xl p-6 border border-outline-variant shadow-sm hover:shadow-md transition-shadow\">\n<div class=\"flex items-center gap-2 mb-3 text-on-surface\">\n<span class=\"material-symbols-outlined\" data-icon=\"horizontal_rule\">horizontal_rule</span>\n<h3 class=\"font-label-md text-label-md uppercase tracking-wider\">Verbo Intransitivo (VI)</h3>\n</div>\n<p class=\"font-body-md text-body-md text-on-surface-variant mb-4\">Apresenta sentido completo, n├úo exigindo complemento.</p>\n<div class=\"bg-surface-container rounded p-3 font-label-md text-label-md text-on-surface\">\n                        Exemplo: O p├íssaro <span class=\"underline\">voou</span>.\n                    </div>\n</div>\n<!-- VL -->\n<div class=\"bg-surface-container-lowest rounded-xl p-6 border border-outline-variant shadow-sm hover:shadow-md transition-shadow md:col-span-2 lg:col-span-1\">\n<div class=\"flex items-center gap-2 mb-3 text-primary\">\n<span class=\"material-symbols-outlined\" data-icon=\"sync_alt\">sync_alt</span>\n<h3 class=\"font-label-md text-label-md uppercase tracking-wider\">Verbo de Liga├º├úo (VL)</h3>\n</div>\n<p class=\"font-body-md text-body-md text-on-surface-variant mb-4\">Liga o sujeito ao seu predicativo, indicando estado.</p>\n<div class=\"bg-surface-container rounded p-3 font-label-md text-label-md text-on-surface\">\n                        Exemplo: Ela <span class=\"text-primary underline\">est├í</span> <span class=\"font-bold\">cansada</span>.\n                    </div>\n</div>\n</div>\n</section>\n<!-- Quiz App Container -->\n<section class=\"bg-surface-container-lowest rounded-xl border border-outline-variant shadow-sm p-card-padding\" id=\"app\">\n<!-- Dynamically populated by JS -->\n<div class=\"text-center py-12\">\n<span class=\"material-symbols-outlined animate-spin text-primary\" data-icon=\"sync\">sync</span>\n<p class=\"mt-4 font-body-md text-on-surface-variant\">Carregando Quiz Interativo...</p>\n</div>\n</section>\n</main>\n<!-- BottomNavBar (Mobile) -->\n<nav class=\"md:hidden bg-surface-container-lowest dark:bg-inverse-surface shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.1)] fixed bottom-0 w-full z-50 flex justify-around items-center p-2 rounded-t-xl\">\n<div class=\"flex flex-col items-center justify-center text-on-surface-variant dark:text-surface-variant px-4 py-1 hover:bg-surface-variant transition-colors cursor-pointer rounded-xl\">\n<span class=\"material-symbols-outlined\" data-icon=\"home\">home</span>\n<span class=\"font-label-sm text-label-sm mt-1\">In├¡cio</span>\n</div>\n<div class=\"flex flex-col items-center justify-center bg-primary-container dark:bg-primary text-on-primary-container dark:text-on-primary rounded-xl px-4 py-1 cursor-pointer scale-95 transition-transform\">\n<span class=\"material-symbols-outlined\" data-icon=\"menu_book\" data-weight=\"fill\" style=\"font-variation-settings: 'FILL' 1;\">menu_book</span>\n<span class=\"font-label-sm text-label-sm mt-1\">Verbos</span>\n</div>\n<div class=\"flex flex-col items-center justify-center text-on-surface-variant dark:text-surface-variant px-4 py-1 hover:bg-surface-variant transition-colors cursor-pointer rounded-xl\">\n<span class=\"material-symbols-outlined\" data-icon=\"quiz\">quiz</span>\n<span class=\"font-label-sm text-label-sm mt-1\">Quiz</span>\n</div>\n<div class=\"flex flex-col items-center justify-center text-on-surface-variant dark:text-surface-variant px-4 py-1 hover:bg-surface-variant transition-colors cursor-pointer rounded-xl\">\n<span class=\"material-symbols-outlined\" data-icon=\"leaderboard\">leaderboard</span>\n<span class=\"font-label-sm text-label-sm mt-1\">Ranking</span>\n</div>\n</nav>\n<!-- JavaScript App Logic -->\n<script>\n        const questionPool = [\n            {\n                id: 1,\n                stem: \"Na ora├º├úo 'A popula├º├úo assistiu ao debate com aten├º├úo', o verbo assistir ├® classificado como:\",\n                options: [\n                    { id: 'a', text: \"Verbo Transitivo Direto (VTD)\", explanation: \"Incorreto. O verbo 'assistir' no sentido de 'ver/presenciar' exige a preposi├º├úo 'a'.\" },\n                    { id: 'b', text: \"Verbo Transitivo Indireto (VTI)\", isCorrect: true, explanation: \"Correto. O verbo 'assistir' (ver/presenciar) exige a preposi├º├úo 'a' (ao debate).\" },\n                    { id: 'c', text: \"Verbo Intransitivo (VI)\", explanation: \"Incorreto. Quem assiste (v├¬), assiste A algo.\" },\n                    { id: 'd', text: \"Verbo Transitivo Direto e Indireto (VTDI)\", explanation: \"Incorreto. N├úo h├í um objeto direto na ora├º├úo.\" }\n                ]\n            },\n            {\n                id: 2,\n                stem: \"Analise a frase: 'O professor entregou as provas aos alunos'. A classifica├º├úo correta do verbo entregar ├®:\",\n                options: [\n                    { id: 'a', text: \"Verbo Intransitivo (VI)\", explanation: \"Incorreto. O verbo entregar pede complemento.\" },\n                    { id: 'b', text: \"Verbo Transitivo Direto (VTD)\", explanation: \"Incorreto. Falta a parte 'aos alunos', que ├® o objeto indireto.\" },\n                    { id: 'c', text: \"Verbo Transitivo Direto e Indireto (VTDI)\", isCorrect: true, explanation: \"Correto. Entrega-se algo (as provas - OD) a algu├®m (aos alunos - OI).\" },\n                    { id: 'd', text: \"Verbo de Liga├º├úo (VL)\", explanation: \"Incorreto. Entregar indica a├º├úo, n├úo estado.\" }\n                ]\n            },\n            {\n                id: 3,\n                stem: \"Em 'As crian├ºas dormem tranquilamente', o verbo dormir classifica-se como:\",\n                options: [\n                    { id: 'a', text: \"Verbo Intransitivo (VI)\", isCorrect: true, explanation: \"Correto. A a├º├úo de dormir tem sentido completo ('tranquilamente' ├® adjunto adverbial de modo).\" },\n                    { id: 'b', text: \"Verbo Transitivo Direto (VTD)\", explanation: \"Incorreto. N├úo h├í objeto recebendo a a├º├úo diretamente.\" },\n                    { id: 'c', text: \"Verbo de Liga├º├úo (VL)\", explanation: \"Incorreto. Dormir ├® a├º├úo, n├úo estado.\" },\n                    { id: 'd', text: \"Verbo Transitivo Indireto (VTI)\", explanation: \"Incorreto. N├úo h├í objeto com preposi├º├úo.\" }\n                ]\n            },\n            {\n                id: 4,\n                stem: \"Na frase 'O c├®u continua nublado', o verbo continuar funciona como:\",\n                options: [\n                    { id: 'a', text: \"Verbo Transitivo Direto (VTD)\", explanation: \"Incorreto. 'Nublado' n├úo ├® objeto, ├® caracter├¡stica do sujeito.\" },\n                    { id: 'b', text: \"Verbo Intransitivo (VI)\", explanation: \"Incorreto. Precisa de predicativo para ter sentido na frase.\" },\n                    { id: 'c', text: \"Verbo de Liga├º├úo (VL)\", isCorrect: true, explanation: \"Correto. 'Continuar' liga o sujeito (O c├®u) a um estado (nublado).\" },\n                    { id: 'd', text: \"Verbo Transitivo Indireto (VTI)\", explanation: \"Incorreto. N├úo h├í objeto indireto.\" }\n                ]\n            },\n            {\n                id: 5,\n                stem: \"Identifique a classifica├º├úo do verbo na ora├º├úo: 'N├│s compramos um carro novo.'\",\n                options: [\n                    { id: 'a', text: \"Verbo Transitivo Direto (VTD)\", isCorrect: true, explanation: \"Correto. Quem compra, compra algo ('um carro novo' - OD sem preposi├º├úo obrigat├│ria).\" },\n                    { id: 'b', text: \"Verbo Transitivo Indireto (VTI)\", explanation: \"Incorreto. N├úo h├í preposi├º├úo ligando o verbo ao complemento.\" },\n                    { id: 'c', text: \"Verbo Intransitivo (VI)\", explanation: \"Incorreto. A frase ficaria incompleta sem o complemento.\" },\n                    { id: 'd', text: \"Verbo de Liga├º├úo (VL)\", explanation: \"Incorreto. Comprar ├® a├º├úo.\" }\n                ]\n            },\n            {\n                id: 6,\n                stem: \"Em 'Ele aspirava ao cargo de gerente', o verbo aspirar ├®:\",\n                options: [\n                    { id: 'a', text: \"Verbo Transitivo Direto (VTD)\", explanation: \"Incorreto. No sentido de desejar/almejar, 'aspirar' ├® VTI.\" },\n                    { id: 'b', text: \"Verbo Transitivo Indireto (VTI)\", isCorrect: true, explanation: \"Correto. Aspirar no sentido de almejar exige a preposi├º├úo 'a'.\" },\n                    { id: 'c', text: \"Verbo Intransitivo (VI)\", explanation: \"Incorreto. Pede complemento (ao cargo).\" },\n                    { id: 'd', text: \"Verbo de Liga├º├úo (VL)\", explanation: \"Incorreto. Indica a├º├úo de desejar.\" }\n                ]\n            }\n        ];\n\n        // App State\n        let currentQuestions = [];\n        let userAnswers = {};\n        let isSubmitted = false;\n\n        function shuffleArray(array) {\n            const newArr = [...array];\n            for (let i = newArr.length - 1; i > 0; i--) {\n                const j = Math.floor(Math.random() * (i + 1));\n                [newArr[i], newArr[j]] = [newArr[j], newArr[i]];\n            }\n            return newArr;\n        }\n\n        function initQuiz() {\n            // Select 5 random questions\n            currentQuestions = shuffleArray(questionPool).slice(0, 5);\n            userAnswers = {};\n            isSubmitted = false;\n            renderQuiz();\n        }\n\n        function handleSelectOption(qIndex, optionId) {\n            if (isSubmitted) return;\n            userAnswers[qIndex] = optionId;\n            renderQuiz();\n        }\n\n        function handleSubmit() {\n            if (Object.keys(userAnswers).length < currentQuestions.length) {\n                alert(\"Por favor, responda todas as quest├Áes antes de enviar.\");\n                return;\n            }\n            isSubmitted = true;\n            renderQuiz();\n        }\n\n        function renderQuiz() {\n            const app = document.getElementById('app');\n            let html = '';\n\n            // Header progress\n            const progress = Object.keys(userAnswers).length;\n            const progressPercent = (progress / currentQuestions.length) * 100;\n\n            html += `\n                <div class=\"mb-8\">\n                    <div class=\"flex justify-between items-center mb-2\">\n                        <h2 class=\"font-headline-md text-headline-md text-on-surface\">Quiz Pr├ítico</h2>\n                        <span class=\"font-label-sm text-label-sm text-on-surface-variant\">${progress}/${currentQuestions.length} respondidas</span>\n                    </div>\n                    <div class=\"w-full bg-surface-variant rounded-full h-2\">\n                        <div class=\"bg-primary h-2 rounded-full transition-all duration-300\" style=\"width: ${progressPercent}%\"></div>\n                    </div>\n                </div>\n                <div class=\"space-y-12\">\n            `;\n\n            if (!isSubmitted) {\n                // Render Questions\n                currentQuestions.forEach((q, qIndex) => {\n                    html += `\n                        <div class=\"space-y-4\">\n                            <h3 class=\"font-body-lg text-body-lg text-on-surface font-semibold\">\n                                <span class=\"text-primary mr-2\">${qIndex + 1}.</span>${q.stem}\n                            </h3>\n                            <div class=\"space-y-2 pl-6\">\n                    `;\n\n                    q.options.forEach(opt => {\n                        const isSelected = userAnswers[qIndex] === opt.id;\n                        html += `\n                            <div onclick=\"handleSelectOption(${qIndex}, '${opt.id}')\" \n                                 class=\"quiz-option p-4 rounded-lg border ${isSelected ? 'selected' : 'border-outline-variant'} flex items-start gap-4\">\n                                <div class=\"w-6 h-6 rounded-full border-2 ${isSelected ? 'border-primary flex items-center justify-center' : 'border-outline-variant'} shrink-0 mt-0.5\">\n                                    ${isSelected ? '<div class=\"w-3 h-3 bg-primary rounded-full\"></div>' : ''}\n                                </div>\n                                <div>\n                                    <span class=\"font-label-md text-label-md mr-2\">${opt.id.toUpperCase()}.</span>\n                                    <span class=\"font-body-md text-body-md text-on-surface\">${opt.text}</span>\n                                </div>\n                            </div>\n                        `;\n                    });\n\n                    html += `</div></div>`;\n                });\n\n                html += `\n                    <div class=\"pt-8 flex justify-end border-t border-outline-variant\">\n                        <button onclick=\"handleSubmit()\" \n                                class=\"bg-primary text-on-primary font-label-md text-label-md px-6 py-3 rounded-full hover:bg-on-primary-fixed-variant transition-colors flex items-center gap-2\"\n                                ${progress < currentQuestions.length ? 'opacity-50 cursor-not-allowed' : ''}>\n                            Enviar Respostas\n                            <span class=\"material-symbols-outlined\" data-icon=\"send\">send</span>\n                        </button>\n                    </div>\n                `;\n\n            } else {\n                // Render Results\n                let score = 0;\n                currentQuestions.forEach((q, qIndex) => {\n                    const selectedOptId = userAnswers[qIndex];\n                    const selectedOpt = q.options.find(o => o.id === selectedOptId);\n                    if (selectedOpt && selectedOpt.isCorrect) score++;\n                });\n\n                const isPerfect = score === currentQuestions.length;\n\n                html += `\n                    <div class=\"text-center p-8 bg-${isPerfect ? 'surface-container-low' : 'surface-variant'} rounded-xl mb-8\">\n                        <span class=\"material-symbols-outlined text-4xl text-${isPerfect ? 'secondary' : 'primary'} mb-4\" data-icon=\"${isPerfect ? 'workspace_premium' : 'analytics'}\">\n                            ${isPerfect ? 'workspace_premium' : 'analytics'}\n                        </span>\n                        <h2 class=\"font-headline-lg text-headline-lg text-on-surface mb-2\">Seu Resultado: ${score}/${currentQuestions.length}</h2>\n                        <p class=\"font-body-md text-body-md text-on-surface-variant\">\n                            ${isPerfect ? 'Excelente! Voc├¬ domina a transitividade verbal.' : 'Bom esfor├ºo! Revise as explica├º├Áes abaixo para melhorar.'}\n                        </p>\n                    </div>\n                `;\n\n                currentQuestions.forEach((q, qIndex) => {\n                    const selectedOptId = userAnswers[qIndex];\n                    const selectedOpt = q.options.find(o => o.id === selectedOptId);\n                    const isCorrect = selectedOpt && selectedOpt.isCorrect;\n\n                    html += `\n                        <div class=\"space-y-4 pb-8 border-b border-outline-variant last:border-0\">\n                            <h3 class=\"font-body-lg text-body-lg text-on-surface font-semibold\">\n                                <span class=\"${isCorrect ? 'text-secondary' : 'text-error'} mr-2\">\n                                    <span class=\"material-symbols-outlined align-middle\" data-icon=\"${isCorrect ? 'check_circle' : 'cancel'}\">${isCorrect ? 'check_circle' : 'cancel'}</span>\n                                </span>\n                                ${q.stem}\n                            </h3>\n                            <div class=\"space-y-2 pl-8\">\n                    `;\n\n                    q.options.forEach(opt => {\n                        const isUserChoice = opt.id === selectedOptId;\n                        let optionClass = \"border-outline-variant opacity-50\";\n                        if (isUserChoice && opt.isCorrect) optionClass = \"correct\";\n                        else if (isUserChoice && !opt.isCorrect) optionClass = \"incorrect\";\n                        else if (!isUserChoice && opt.isCorrect) optionClass = \"correct border-dashed\";\n\n                        html += `\n                            <div class=\"quiz-option disabled p-4 rounded-lg border ${optionClass} flex flex-col gap-2\">\n                                <div class=\"flex items-start gap-4\">\n                                    <div class=\"w-6 h-6 rounded-full border-2 ${isUserChoice ? 'border-current' : 'border-outline-variant'} flex items-center justify-center shrink-0 mt-0.5\">\n                                        ${isUserChoice ? '<div class=\"w-3 h-3 bg-current rounded-full\"></div>' : ''}\n                                    </div>\n                                    <div>\n                                        <span class=\"font-label-md text-label-md mr-2\">${opt.id.toUpperCase()}.</span>\n                                        <span class=\"font-body-md text-body-md text-on-surface\">${opt.text}</span>\n                                    </div>\n                                </div>\n                                ${(isUserChoice || opt.isCorrect) ? `\n                                    <div class=\"mt-2 ml-10 p-3 bg-surface-container-lowest rounded border border-outline-variant font-body-sm text-on-surface-variant\">\n                                        <strong>Explica├º├úo:</strong> ${opt.explanation}\n                                    </div>\n                                ` : ''}\n                            </div>\n                        `;\n                    });\n\n                    html += `</div></div>`;\n                });\n\n                html += `\n                    <div class=\"pt-8 flex justify-center\">\n                        <button onclick=\"initQuiz()\" \n                                class=\"border border-primary text-primary font-label-md text-label-md px-6 py-3 rounded-full hover:bg-primary-fixed transition-colors flex items-center gap-2\">\n                            Tentar Novamente\n                            <span class=\"material-symbols-outlined\" data-icon=\"refresh\">refresh</span>\n                        </button>\n                    </div>\n                `;\n            }\n\n            html += `</div>`;\n            app.innerHTML = html;\n        }\n\n        // Initialize on load\n        document.addEventListener('DOMContentLoaded', () => {\n            initQuiz();\n        });\n    </script>\n</body></html>"}
